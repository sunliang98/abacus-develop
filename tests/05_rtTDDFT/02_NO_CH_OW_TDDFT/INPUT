orbital_dir        ../../PP_ORB

nbands             10
calculation        md
esolver_type       tddft
basis_type         lcao
gamma_only         0
ecutwfc            5

#Parameter (Electronic Structure)
scf_nmax           50

smearing_method    gaussian
